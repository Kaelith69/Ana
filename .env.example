# Copy this file to .env and fill in your real values.
# NEVER commit .env — it contains secret keys.

# ── Discord ───────────────────────────────────────────────────────────────────
# Get this from https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# ── AI Model Keys ─────────────────────────────────────────────────────────────
# Groq (primary model) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini fallback 1 — https://aistudio.google.com/app/apikey
GEN1_API_KEY=your_gemini_gen1_api_key_here

# Google Gemini fallback 2 — https://aistudio.google.com/app/apikey
GEN2_API_KEY=your_gemini_gen2_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────
# Uncomment and change any of these to customise behaviour without touching code.

# Custom system prompt (see config.py for preset examples)
# SYSTEM_PROMPT=you are ana, a ...

# Joke frequency (0.0 = never, 1.0 = always) — default 0.15
# JOKE_CHANCE=0.15

# Seconds between joke attempts in the same channel — default 60
# JOKE_COOLDOWN=60

# Timeout in seconds for the dad-joke API — default 8
# JOKE_FETCH_TIMEOUT=8

# Override the dad-joke API endpoint — default https://icanhazdadjoke.com/
# JOKE_API_URL=https://icanhazdadjoke.com/
